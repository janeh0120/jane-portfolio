---
interface SerializedComment {
  id: string;
  pageUrl: string;
  selector: string;
  elementDisplayName: string;
  category: string;
  comment: string;
  deviceType: string;
  os: string;
  viewportWidth: number;
  scrollY: number;
  upvoteCount: number;
  createdAt: string;
}

interface SerializedVersion {
  id: string;
  label: string;
  deployUrl: string | null;
  isActive: boolean;
  createdAt: string;
  summary?: string;
}

interface Props {
  comments: SerializedComment[];
  versions: SerializedVersion[];
  selectedVersionId: string;
  frameBaseUrl: string;
  liveSiteUrl: string;
}

const { comments, versions, selectedVersionId, frameBaseUrl, liveSiteUrl } = Astro.props;
const selectedVersion = versions.find((version) => version.id === selectedVersionId);
---

<div class="admin-review-toolbar" data-comment-ui>
  <div class="admin-review-toolbar-left">
    <a href="/history" class="admin-review-badge transition hover:opacity-80">← All versions</a>
    <label class="sr-only" for="history-version-select">Portfolio version</label>
    <select id="history-version-select" class="admin-review-version-select">
      {
        versions.map((version) => (
          <option value={version.id} selected={version.id === selectedVersionId}>
            {version.label}
            {version.isActive ? ' (live)' : ''}
          </option>
        ))
      }
    </select>
    {
      selectedVersion?.summary && (
        <p class="admin-review-toolbar-meta hidden md:block">{selectedVersion.summary}</p>
      )
    }
  </div>
  <div class="flex flex-wrap items-center gap-3 sm:gap-4">
    <p class="admin-review-toolbar-meta" id="history-review-summary">
      {comments.length} comment{comments.length === 1 ? '' : 's'} on this version
    </p>
    {
      selectedVersion?.isActive ? (
        <a href={liveSiteUrl} class="text-sm font-medium text-ink transition hover:opacity-70">
          Open live site →
        </a>
      ) : (
        <span class="text-sm text-muted">Archived — comments are read-only</span>
      )
    }
  </div>
</div>

{
  selectedVersion?.summary && (
    <p class="border-b border-line bg-canvas px-4 py-3 text-sm text-muted md:hidden">
      {selectedVersion.summary}
    </p>
  )
}

<div id="history-site-shell" class="site-shell admin-review-shell">
  <div id="history-site-canvas" class="site-canvas admin-review-canvas">
    <iframe
      id="history-portfolio-frame"
      class="admin-review-frame"
      title="Portfolio preview"
      src={frameBaseUrl}
    ></iframe>
  </div>

  <aside class="comment-sidebar" id="history-comment-sidebar" data-comment-ui aria-label="Comments">
    <div class="comment-sidebar-panel">
      <div class="comment-sidebar-header">
        <div class="comment-sidebar-header-row">
          <span class="comment-sidebar-title">Comments</span>
        </div>
        <div class="comment-sidebar-tabs" role="tablist" aria-label="Comment filter">
          <button
            type="button"
            id="history-scope-page"
            class="comment-sidebar-tab is-active"
            role="tab"
            aria-selected="true"
          >
            This page
          </button>
          <button
            type="button"
            id="history-scope-all"
            class="comment-sidebar-tab"
            role="tab"
            aria-selected="false"
          >
            All pages
          </button>
        </div>
      </div>
      <div class="comment-sidebar-list" id="history-comment-list" role="tabpanel"></div>
    </div>
  </aside>
</div>

<div class="comment-mode-highlight" id="history-highlight" hidden data-comment-ui></div>

<script define:vars={{ comments, frameBaseUrl }}>
  const CATEGORY_LABELS = {
    '': 'No category',
    accessibility: 'Accessibility',
    content: 'Content',
    'visual-design': 'Visual design',
    bug: 'Bug',
  };

  const versionSelect = document.getElementById('history-version-select');
  const frame = document.getElementById('history-portfolio-frame');
  const sidebarList = document.getElementById('history-comment-list');
  const highlight = document.getElementById('history-highlight');
  const scopePageBtn = document.getElementById('history-scope-page');
  const scopeAllBtn = document.getElementById('history-scope-all');

  let scope = 'page';
  let activeCardId = null;
  let previewCardId = null;
  let pinnedComment = null;

  function categoryLabel(id) {
    return CATEGORY_LABELS[id] ?? 'No category';
  }

  function formatMeta(item) {
    const when = new Intl.DateTimeFormat('en-CA', {
      dateStyle: 'medium',
      timeStyle: 'short',
    }).format(new Date(item.createdAt));
    return `${when} · ${item.deviceType} · ${item.os} · ${item.viewportWidth}px`;
  }

  function pagePathFromUrl(pageUrl) {
    try {
      const url = new URL(pageUrl);
      return url.pathname + url.search;
    } catch {
      return '/';
    }
  }

  function currentFramePath() {
    if (!frame?.contentWindow) return '/';
    try {
      return frame.contentWindow.location.pathname + frame.contentWindow.location.search;
    } catch {
      return pagePathFromUrl(frame.src);
    }
  }

  function resolveFrameUrl(pageUrl) {
    const path = pagePathFromUrl(pageUrl);
    const base = frameBaseUrl.replace(/\/$/, '');
    if (path.startsWith('/admin') || path.startsWith('/api') || path.startsWith('/history')) {
      return `${base}/`;
    }
    return `${base}${path.startsWith('/') ? path : `/${path}`}`;
  }

  function canAccessFrameDocument() {
    try {
      return Boolean(frame?.contentDocument);
    } catch {
      return false;
    }
  }

  function positionHighlightForElement(element) {
    if (!highlight || !frame) return;
    const frameRect = frame.getBoundingClientRect();
    const elRect = element.getBoundingClientRect();
    highlight.hidden = false;
    highlight.classList.add('is-pinned');
    highlight.classList.remove('is-preview');
    highlight.style.top = `${frameRect.top + elRect.top}px`;
    highlight.style.left = `${frameRect.left + elRect.left}px`;
    highlight.style.width = `${elRect.width}px`;
    highlight.style.height = `${elRect.height}px`;
  }

  function hideHighlight() {
    if (!highlight) return;
    highlight.hidden = true;
    highlight.classList.remove('is-pinned', 'is-preview');
  }

  function tryHighlightComment(item) {
    if (!canAccessFrameDocument()) {
      hideHighlight();
      return;
    }
    const doc = frame.contentDocument;
    const target = doc?.querySelector(item.selector);
    if (target instanceof HTMLElement) {
      positionHighlightForElement(target);
    } else {
      hideHighlight();
    }
  }

  function scrollFrameToComment(item) {
    try {
      frame?.contentWindow?.scrollTo({ top: item.scrollY, behavior: 'smooth' });
    } catch {
      /* cross-origin: scroll may be blocked */
    }
  }

  function onFrameReady(item, { pin = true } = {}) {
    scrollFrameToComment(item);
    if (pin) {
      pinnedComment = item;
      tryHighlightComment(item);
      attachFrameScrollListener();
    }
  }

  let scrollListenerAttached = false;

  function attachFrameScrollListener() {
    if (scrollListenerAttached || !canAccessFrameDocument()) return;
    frame?.contentWindow?.addEventListener(
      'scroll',
      () => {
        if (pinnedComment) tryHighlightComment(pinnedComment);
      },
      { passive: true },
    );
    scrollListenerAttached = true;
  }

  function navigateToComment(item, { pin = true } = {}) {
    if (!frame) return;
    const targetUrl = resolveFrameUrl(item.pageUrl);
    let samePage = false;

    try {
      samePage = frame.contentWindow?.location.pathname === new URL(targetUrl).pathname;
    } catch {
      samePage = frame.src === targetUrl;
    }

    if (samePage && canAccessFrameDocument()) {
      onFrameReady(item, { pin });
      return;
    }

    const handleLoad = () => {
      frame?.removeEventListener('load', handleLoad);
      onFrameReady(item, { pin });
    };

    frame.addEventListener('load', handleLoad);
    frame.src = targetUrl;
  }

  function filteredComments() {
    if (scope === 'all') return comments;
    const path = currentFramePath();
    return comments.filter((item) => pagePathFromUrl(item.pageUrl) === path);
  }

  function renderSidebar() {
    if (!sidebarList) return;
    const items = filteredComments();
    sidebarList.innerHTML = '';

    if (items.length === 0) {
      const empty = document.createElement('p');
      empty.className = 'comment-sidebar-empty';
      empty.textContent =
        scope === 'page'
          ? 'No comments on this page for this version.'
          : 'No comments for this version yet.';
      sidebarList.appendChild(empty);
      return;
    }

    for (const item of [...items].reverse()) {
      const card = document.createElement('article');
      card.className = `comment-sidebar-card comment-sidebar-card--readonly${activeCardId === item.id ? ' is-active' : ''}`;
      card.dataset.commentId = item.id;

      const header = document.createElement('div');
      header.className = 'comment-sidebar-card-header';

      const category = document.createElement('span');
      category.className = 'comment-sidebar-card-category-label';
      category.textContent = categoryLabel(item.category);

      const upvotes = document.createElement('span');
      upvotes.className = 'comment-sidebar-card-upvote comment-sidebar-card-upvote--readonly';
      upvotes.textContent = `+1 · ${item.upvoteCount}`;

      header.append(category, upvotes);
      card.appendChild(header);

      const title = document.createElement('p');
      title.className = 'comment-sidebar-card-title';
      title.textContent = item.elementDisplayName;
      card.appendChild(title);

      const body = document.createElement('p');
      body.className = 'comment-sidebar-card-body';
      body.textContent = item.comment;
      card.appendChild(body);

      const meta = document.createElement('p');
      meta.className = 'comment-sidebar-card-meta';
      meta.textContent = formatMeta(item);
      card.appendChild(meta);

      card.addEventListener('click', () => {
        activeCardId = item.id;
        previewCardId = null;
        navigateToComment(item, { pin: true });
        renderSidebar();
      });

      card.addEventListener('mouseenter', () => {
        previewCardId = item.id;
        if (canAccessFrameDocument()) {
          const doc = frame.contentDocument;
          const target = doc?.querySelector(item.selector);
          if (target instanceof HTMLElement) {
            const frameRect = frame.getBoundingClientRect();
            const elRect = target.getBoundingClientRect();
            highlight.hidden = false;
            highlight.classList.add('is-preview');
            highlight.classList.remove('is-pinned');
            highlight.style.top = `${frameRect.top + elRect.top}px`;
            highlight.style.left = `${frameRect.left + elRect.left}px`;
            highlight.style.width = `${elRect.width}px`;
            highlight.style.height = `${elRect.height}px`;
          }
        }
      });

      card.addEventListener('mouseleave', () => {
        if (previewCardId === item.id) {
          previewCardId = null;
          if (pinnedComment) tryHighlightComment(pinnedComment);
          else hideHighlight();
        }
      });

      sidebarList.appendChild(card);
    }
  }

  function setScope(next) {
    scope = next;
    scopePageBtn?.classList.toggle('is-active', next === 'page');
    scopeAllBtn?.classList.toggle('is-active', next === 'all');
    scopePageBtn?.setAttribute('aria-selected', String(next === 'page'));
    scopeAllBtn?.setAttribute('aria-selected', String(next === 'all'));
    renderSidebar();
  }

  versionSelect?.addEventListener('change', () => {
    const versionId = versionSelect.value;
    const url = new URL(window.location.href);
    url.searchParams.set('version', versionId);
    window.location.href = url.toString();
  });

  scopePageBtn?.addEventListener('click', () => setScope('page'));
  scopeAllBtn?.addEventListener('click', () => setScope('all'));

  frame?.addEventListener('load', () => {
    if (scope === 'page') renderSidebar();
  });

  document.body.classList.add('comment-view-comment');
  renderSidebar();
</script>
