---
import { site } from '../data/site';

const base = import.meta.env.BASE_URL;
const root = base.endsWith('/') ? base.slice(0, -1) : base;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

function resolveHref(href: string) {
  if (href.startsWith('/#')) return `${root}${href}`;
  if (href.startsWith('/')) return `${root}${href}`;
  return href;
}

function isActive(href: string) {
  if (href === '/about') return pathname.endsWith('/about');
  if (href === '/extra') return pathname.endsWith('/extra');
  if (href === '/history') return pathname.endsWith('/history');
  if (href === '/#projects') {
    return pathname === '/' || pathname === root;
  }
  return false;
}

const linkClass = (href: string) =>
  [
    'text-sm font-medium transition hover:opacity-70',
    isActive(href) && 'underline decoration-ink/30 underline-offset-4',
  ]
    .filter(Boolean)
    .join(' ');
---

<header class="site-header sticky top-0 z-50 bg-white/70 backdrop-blur-sm">
  <div
    class="relative mx-auto flex max-w-[1400px] items-center justify-between gap-4 px-6 py-5 md:px-10"
  >
    <a
      href={base}
      class="nav-logo inline-flex shrink-0 items-center transition hover:opacity-70"
      aria-label={`${site.name} home`}
    >
      <span
        class="nav-logo-mark block h-7 w-7 shrink-0 bg-ink"
        style={`mask: url('${base}${site.logo}') center / contain no-repeat; -webkit-mask: url('${base}${site.logo}') center / contain no-repeat;`}
      ></span>
    </a>

    <nav
      class="main-nav hidden items-center gap-5 md:flex md:gap-8"
      aria-label="Main"
      data-comment-id="main-nav"
    >
      {
        site.nav.map((item) => (
          <a href={resolveHref(item.href)} class={linkClass(item.href)}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions flex shrink-0 items-center gap-2">
      <div id="comment-toggle-anchor" class="comment-toggle-anchor" data-comment-ui></div>
      <button
        type="button"
        id="mobile-nav-toggle"
        class="mobile-nav-toggle inline-flex h-11 w-11 items-center justify-center rounded-lg border border-line bg-white text-ink transition hover:bg-line/60 md:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
        aria-label="Open menu"
        data-comment-ui
      >
        <svg
          class="mobile-nav-icon-open h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          aria-hidden="true"
        >
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
        <svg
          class="mobile-nav-icon-close hidden h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          aria-hidden="true"
        >
          <path d="M6 6l12 12M18 6 6 18" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-nav-panel"
    class="mobile-nav-panel hidden border-t border-line bg-white/95 px-6 py-4 backdrop-blur-sm md:hidden"
    aria-label="Main"
    hidden
  >
    <ul class="flex flex-col gap-1">
      {
        site.nav.map((item) => (
          <li>
            <a
              href={resolveHref(item.href)}
              class:list={[
                'mobile-nav-link block rounded-lg px-3 py-3 text-base font-medium transition hover:bg-line/60',
                isActive(item.href) && 'bg-line/40',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const panel = document.getElementById('mobile-nav-panel');
  const openIcon = toggle?.querySelector('.mobile-nav-icon-open');
  const closeIcon = toggle?.querySelector('.mobile-nav-icon-close');

  function setOpen(open: boolean) {
    if (!toggle || !panel) return;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    panel.hidden = !open;
    panel.classList.toggle('hidden', !open);
    openIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
    document.body.classList.toggle('mobile-nav-open', open);
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!isOpen);
  });

  panel?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
      toggle.focus();
    }
  });

  window.matchMedia('(min-width: 768px)').addEventListener('change', (event) => {
    if (event.matches) setOpen(false);
  });
</script>
