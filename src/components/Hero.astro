---
import { site } from '../data/site';

const [products, branding, community] = site.hero.filters;
---

<section class="mx-auto max-w-[1400px] px-6 pb-4 pt-8 md:px-10 md:pb-6 md:pt-12">
  <p class="hero-copy max-w-5xl font-serif text-ink">
    {site.hero.intro}
    <em class="hero-emphasis">{site.hero.role}</em>
    {site.hero.middle}
    <button type="button" class="hero-filter" data-filter={products.tag} aria-pressed="false">
      {products.label}
    </button>,{' '}
    <button type="button" class="hero-filter" data-filter={branding.tag} aria-pressed="false">
      {branding.label}
    </button>, and{' '}
    <button type="button" class="hero-filter" data-filter={community.tag} aria-pressed="false">
      {community.label}
    </button>
    {site.hero.outro}
  </p>
</section>

<style>
  .hero-emphasis {
    font-style: italic;
  }

  .hero-filter {
    display: inline;
    color: inherit;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    font-style: italic;
    vertical-align: baseline;
    transition:
      opacity 0.2s ease,
      text-decoration-color 0.2s ease;
  }

  .hero-filter:hover {
    opacity: 0.7;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
  }

  .hero-filter.is-active {
    opacity: 1;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
  }

  .hero-filter.is-dimmed {
    opacity: 0.35;
  }

  .hero-filter.is-dimmed:hover {
    opacity: 0.75;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
  }
</style>
