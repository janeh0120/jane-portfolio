---
import { site } from '../data/site';
---

<section class="mx-auto max-w-[1400px] px-6 pb-10 pt-8 md:px-10 md:pb-16 md:pt-12">
  <div class="hero-stack max-w-5xl font-serif text-ink">
    <p class="hero-line">{site.hero.intro}</p>
    <p class="hero-line hero-emphasis">{site.hero.role}</p>
    <p class="hero-line">{site.hero.middle}</p>
    {
      site.hero.filters.slice(0, 2).map((filter) => (
        <p class="hero-line">
          <button
            type="button"
            class="hero-filter"
            data-filter={filter.tag}
            aria-pressed="false"
          >
            {filter.label}
          </button>
        </p>
      ))
    }
    <p class="hero-line">{site.hero.joiner}</p>
    <p class="hero-line">
      <button
        type="button"
        class="hero-filter"
        data-filter={site.hero.filters[2].tag}
        aria-pressed="false"
      >
        {site.hero.filters[2].label}
      </button>
    </p>
    <p class="hero-line">{site.hero.outro}</p>
  </div>
</section>

<style>
  .hero-stack p {
    margin: 0;
  }

  .hero-stack p + p {
    margin-top: 0.08em;
  }

  .hero-emphasis {
    font-style: italic;
  }

  .hero-filter {
    font: inherit;
    color: inherit;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    font-style: italic;
    text-align: left;
    transition: opacity 0.2s ease;
  }

  .hero-filter:hover {
    opacity: 0.55;
  }

  .hero-filter.is-active {
    opacity: 1;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
  }

  .hero-filter.is-dimmed {
    opacity: 0.35;
  }
</style>
