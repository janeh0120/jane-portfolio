---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface NavItem {
  label: string;
  href: string;
}

interface MetaItem {
  label: string;
  value: string;
}

interface Props {
  title: string;
  heading: string;
  role: string;
  team: string;
  timeline: string;
  projectType: string;
  nav: NavItem[];
  commentId?: string;
}

const { title, heading, role, team, timeline, projectType, nav, commentId } = Astro.props;
const studyCommentId = commentId ?? `case-study-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
const base = import.meta.env.BASE_URL;
const home = base;
---

<Layout title={`${title} — Jane Hou's Portfolio`}>
  <Header />
  <main class="mx-auto max-w-[1400px] px-6 pb-24 md:px-10">
    <a
      href={home}
      class="mb-10 inline-block pt-6 text-sm text-muted transition hover:text-ink"
    >
      ← Back to Home
    </a>

    <div class="grid gap-12 lg:grid-cols-[200px_1fr] lg:gap-20">
      <aside class="lg:sticky lg:top-24 lg:self-start">
        <nav class="case-study-nav flex flex-wrap gap-4 lg:flex-col lg:gap-3" aria-label="Case study">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class="text-sm text-muted transition hover:text-ink"
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </aside>

      <article class="min-w-0 max-w-3xl" data-comment-id={studyCommentId}>
        <h1 class="text-3xl font-medium tracking-tight text-ink md:text-4xl">{heading}</h1>

        <dl class="mt-10 grid gap-6 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium text-muted">Role:</dt>
            <dd class="mt-1 text-base text-ink">{role}</dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-muted">Team:</dt>
            <dd class="mt-1 text-base text-ink">{team}</dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-muted">Timeline:</dt>
            <dd class="mt-1 text-base text-ink">{timeline}</dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-muted">Project Type:</dt>
            <dd class="mt-1 text-base text-ink">{projectType}</dd>
          </div>
        </dl>

        <div class="case-study-content mt-14 space-y-16">
          <slot />
        </div>
      </article>
    </div>
  </main>
  <SiteFooter />
</Layout>

<script>
  const nav = document.querySelector('.case-study-nav');
  if (nav) {
    nav.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener('click', (event) => {
        const href = link.getAttribute('href');
        if (!href?.startsWith('#')) return;

        const target = document.getElementById(href.slice(1));
        if (!target) return;

        event.preventDefault();
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        target.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
        history.replaceState(null, '', href);
      });
    });
  }
</script>

<style>
  .case-study-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .case-study-content :global(h3) {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
    text-transform: lowercase;
  }

  .case-study-content :global(p) {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-ink);
    margin: 0;
  }

  .case-study-content :global(section) {
    scroll-margin-top: 6rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(html:has(.case-study-nav)) {
      scroll-behavior: smooth;
    }
  }

  .case-study-content :global(.lead) {
    font-size: 1.5rem;
    line-height: 1.35;
    letter-spacing: -0.02em;
    font-weight: 500;
  }

  .case-study-content :global(ol) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 2rem;
  }

  .case-study-content :global(ol li h2) {
    font-size: 1.25rem;
  }

  .case-study-content :global(.case-study-figure) {
    margin: 1.5rem 0 0;
  }

  .case-study-content :global(.case-study-figure img) {
    display: block;
    width: 100%;
    border-radius: 12px;
    background: #fafafa;
  }

  .case-study-content :global(.case-study-figure video) {
    display: block;
    width: 100%;
    border-radius: 12px;
    background: #000;
  }

  .case-study-content :global(.case-study-figure--placeholder img) {
    border: 1px dashed #c8c8c8;
  }

  .case-study-content :global(.case-study-figure figcaption) {
    margin-top: 0.5rem;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-muted);
  }

  .case-study-content :global(.case-study-figure-row) {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 640px) {
    .case-study-content :global(.case-study-figure-row) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .case-study-content :global(.case-study-stats) {
    display: grid;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 640px) {
    .case-study-content :global(.case-study-stats) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .case-study-content :global(.case-study-stat) {
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-line);
    border-radius: 12px;
    background: var(--color-canvas);
  }

  .case-study-content :global(.case-study-stat strong) {
    display: block;
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .case-study-content :global(.case-study-stat span) {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .case-study-content :global(ul.case-study-list) {
    margin: 0.75rem 0 0;
    padding-left: 1.25rem;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink);
  }
</style>
