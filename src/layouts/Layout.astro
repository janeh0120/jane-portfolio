---
import '../styles/global.css';
import '../styles/comment-mode.css';
import { site } from '../data/site';
import CommentMode from '../components/CommentMode.astro';

interface Props {
  title?: string;
  description?: string;
  showCommentMode?: boolean;
}

const {
  title = site.title,
  description = site.description,
  showCommentMode = true,
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body
    class:list={[
      'min-h-screen text-ink antialiased',
      showCommentMode ? 'comment-feedback-root comment-view-only' : 'bg-canvas',
    ]}
  >
    {
      showCommentMode ? (
        <div id="site-shell" class="site-shell">
          <div id="site-canvas" class="site-canvas">
            <slot />
          </div>
        </div>
      ) : (
        <slot />
      )
    }
    {showCommentMode && <CommentMode />}
  </body>
</html>
