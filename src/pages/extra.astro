---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ExtraGallery from '../components/extra/ExtraGallery.astro';
import ExtraFooter from '../components/extra/ExtraFooter.astro';
import { site } from '../data/site';
import '../styles/extra.css';
---

<Layout title={`Extra — ${site.title}`}>
  <div class="extra-page">
    <Header />
    <main>
      <ExtraGallery />
    </main>
    <ExtraFooter />
  </div>
</Layout>
